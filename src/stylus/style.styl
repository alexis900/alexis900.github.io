body 
    font-family -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif
    color var(--veryDarkBlue)
    background lightgray
    margin: 0
    section
        border 1px solid red

.u-wrapper
  max-width 1280px
  margin auto
  padding 0 1em

