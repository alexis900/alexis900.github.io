.menu
    visibility: hidden
    position: absolute
    left 0
    right 0
    top 100%
    background rgba(47, 53, 79, 0.9)
    height 100vh
    transform translateY(-50px)
    transition .3s transform, .3s opacity 
    will-change transform

    ul
        padding 0
        list-style none
    li
        border-top 1px solid var(--grayishBlue)
    a
        color white
        text-decoration none
        text-transform uppercase
        display block
        text-align center
        padding 1em
        letter-spacing 2px
        &:active
            background url('../images/icon-hamburger.svg') no-repeat center
            visibility hidden
    &-checkbox 
        margin 2em
        display none

        &:checked
            & ~ .header .menu-open
                background url('../images/icon-close.svg') no-repeat center
            & ~ .header
                background rgba(47, 53, 79, .9)
                .menu  
                    transform translateY(0)
                    visibility visible
                    opacity 1

    &-open
        user-select none
        width 40px
        height 40px
        display inline-flex
        cursor pointer
        background url('../images/icon-hamburger.svg') no-repeat center